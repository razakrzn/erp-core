{
  "info": {
    "_postman_id": "0f30ab2e-f328-4470-a81f-0ef2f271d80f",
    "name": "Goods Receipt API",
    "description": "API collection for managing Goods Receipts (GRN), material intake items, and received goods photos in the ERP inventory module.",
