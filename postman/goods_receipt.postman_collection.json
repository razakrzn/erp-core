  },
  "item": [
    {
      "name": "Goods Receipt",
      "item": [
        {
          "name": "List Goods Receipts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/inventory/goods-receipts/?page=1&search=&ordering=-created_at",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "inventory",
                "goods-receipts",
                ""
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "PO-000001",
                  "disabled": true
                },
                {
                  "key": "ordering",
                  "value": "-created_at",
                  "disabled": true
                }
              ]
            },
            "description": "Retrieve a paginated list of goods receipts. Supports search and ordering."
          },
          "response": []
        },
        {
          "name": "Create Goods Receipt (Multipart with data JSON)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "data",
                  "value": "{\n  \"purchase_order_id\": {{purchase_order_id}},\n  \"grn_recording_date\": \"2026-06-01\",\n  \"vendor_invoice_no\": \"INV-2026-001\",\n  \"vendor_invoice_date\": \"2026-06-01\",\n  \"delivery_challan_no\": \"DC-2026-001\",\n  \"delivery_challan_date\": \"2026-06-01\",\n  \"overall_quality_status\": \"accepted\",\n  \"quality_notes\": \"All received items inspected.\"\n}",
                  "type": "text"
                },
                {
                  "key": "material_intakes",
                  "value": "[\n  {\n    \"client_line_id\": \"line_1\",\n    \"purchase_order_line_item\": {{purchase_order_line_item_id}},\n    \"qty_good\": \"8.00\",\n    \"qty_rejected\": \"2.00\",\n    \"rejection_reason\": \"Scratch marks\"\n  },\n  {\n    \"client_line_id\": \"line_2\",\n    \"purchase_order_line_item\": {{purchase_order_line_item_id_2}},\n    \"qty_good\": \"5.00\",\n    \"qty_rejected\": \"0.00\",\n    \"rejection_reason\": \"\"\n  }\n]",
                  "type": "text"
                },
                {
                  "key": "vendor_delivery_challan",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "vendor_invoice",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "received_goods_photo_files",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "received_goods_photo_files",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "defect_photo_line_1",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/inventory/goods-receipts/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "inventory",
                "goods-receipts",
                ""
              ]
            },
            "description": "Create with multipart form-data: `data` (text JSON object), `material_intakes` (text JSON array), and files. For defect photos, set `client_line_id` on each material_intake and send file key as `defect_photo_<client_line_id>`."
          },
          "response": []
        },
        {
          "name": "Get Goods Receipt Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/inventory/goods-receipts/{{goods_receipt_id}}/",
