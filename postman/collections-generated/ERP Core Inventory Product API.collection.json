{
  "info": {
    "_postman_id": "5eb8d9bf-7dc6-45af-bef4-3a8d79ff2f0f",
    "name": "ERP Core Inventory Product API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for ERP Core inventory product endpoints."
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (pm.collectionVariables.get('token') && !pm.collectionVariables.get('access_token')) {",
          "    pm.collectionVariables.set('access_token', pm.collectionVariables.get('token'));",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "username",
      "value": "admin"
    },
    {
      "key": "password",
      "value": "password"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "product_id",
      "value": "1"
    },
    {
      "key": "search",
      "value": ""
    },
    {
      "key": "ordering",
      "value": "-created_at"
    },
    {
      "key": "category_id",
      "value": "1"
    },
    {
      "key": "brand_id",
      "value": "1"
    },
    {
      "key": "material_id",
      "value": "1"
    },
    {
      "key": "size_id",
      "value": "1"
    },
    {
      "key": "thickness_id",
      "value": "1"
    },
    {
      "key": "grade_id",
      "value": "1"
    },
    {
      "key": "finish_id",
      "value": "1"
    },
    {
      "key": "unit_id",
      "value": "1"
    },
    {
      "key": "vendor_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const data = json.data || {};",
                  "if (data.access) {",
                  "    pm.collectionVariables.set('access_token', data.access);",
                  "    pm.collectionVariables.set('token', data.access);",
                  "}",
                  "if (data.refresh) {",
                  "    pm.collectionVariables.set('refresh_token', data.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login",
                ""
              ]
            },
            "description": "Login and store JWT access/refresh tokens in collection variables."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "refresh",
                ""
              ]
            },
            "description": "Refresh the JWT access token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/inventory/products/?search={{search}}&ordering={{ordering}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "inventory",
                "products",
                ""
              ],
              "query": [
                {
                  "key": "search",
                  "value": "{{search}}"
                },
                {
                  "key": "ordering",
                  "value": "{{ordering}}"
                }
              ]
            },
            "description": "List inventory products. Supports search by product fields and related lookup/vendor names."
          },
          "response": []
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Marine Plywood 18mm\",\n  \"sku\": \"PLY-18-001\",\n  \"product_code\": \"PRD-0001\",\n  \"status\": \"active\",\n  \"price\": \"250.00\",\n  \"standard_cost\": \"190.00\",\n  \"reorder_level\": 20,\n  \"preferred_supplier\": {{vendor_id}},\n  \"lead_time_days\": 7,\n  \"max_stock_level\": 120,\n  \"moq\": 5,\n  \"opening_stock\": 50,\n  \"opening_stock_date\": \"2026-04-03\",\n  \"hsn_sac_code\": \"4412\",\n  \"admin_notes\": \"Initial stock for Dubai warehouse.\",\n  \"category\": {{category_id}},\n  \"brand\": {{brand_id}},\n  \"material\": {{material_id}},\n  \"size\": {{size_id}},\n  \"thickness\": {{thickness_id}},\n  \"grade\": {{grade_id}},\n  \"finish\": {{finish_id}},\n  \"unit\": {{unit_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/inventory/products/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "inventory",
                "products",
                ""
              ]
            },
            "description": "Create a product with the current inventory product schema."
          },
          "response": []
        },
        {
          "name": "Retrieve Product",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/inventory/products/{{product_id}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "inventory",
                "products",
                "{{product_id}}",
                ""
              ]
            },
            "description": "Retrieve a single product by id."
          },
          "response": []
        },
        {
          "name": "Update Product (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Marine Plywood 18mm Premium\",\n  \"sku\": \"PLY-18-001\",\n  \"product_code\": \"PRD-0001\",\n  \"status\": \"active\",\n  \"price\": \"275.00\",\n  \"standard_cost\": \"205.00\",\n  \"reorder_level\": 25,\n  \"preferred_supplier\": {{vendor_id}},\n  \"lead_time_days\": 10,\n  \"max_stock_level\": 150,\n  \"moq\": 10,\n  \"opening_stock\": 60,\n  \"opening_stock_date\": \"2026-04-03\",\n  \"hsn_sac_code\": \"4412\",\n  \"admin_notes\": \"Updated after supplier renegotiation.\",\n  \"category\": {{category_id}},\n  \"brand\": {{brand_id}},\n  \"material\": {{material_id}},\n  \"size\": {{size_id}},\n  \"thickness\": {{thickness_id}},\n  \"grade\": {{grade_id}},\n  \"finish\": {{finish_id}},\n  \"unit\": {{unit_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/inventory/products/{{product_id}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "inventory",
                "products",
                "{{product_id}}",
                ""
              ]
            },
            "description": "Replace an existing product."
          },
          "response": []
        },
        {
          "name": "Partial Update Product (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"inactive\",\n  \"reorder_level\": 30,\n  \"standard_cost\": \"210.00\",\n  \"admin_notes\": \"Temporarily inactive pending stock review.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/inventory/products/{{product_id}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "inventory",
                "products",
                "{{product_id}}",
                ""
              ]
            },
            "description": "Partially update selected product fields."
          },
          "response": []
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/v1/inventory/products/{{product_id}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "inventory",
                "products",
                "{{product_id}}",
                ""
              ]
            },
            "description": "Delete a product by id."
          },
          "response": []
        }
      ]
    }
  ]
}
